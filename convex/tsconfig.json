{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ES2021", "dom"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "convex/_generated/api": ["./_generated/api"],
      "convex/_generated/server": ["./_generated/server"],
      "convex/_generated/dataModel": ["./_generated/dataModel"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": []
}
